# KIE AI API key — https://kie.ai (used for video generation)
KIE_API_KEY=your_kie_api_key_here

# Telegram Bot token — required for Telegram Stars payments and webhook
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Public URL of this app — video generation (Railway URL, must be https)
BASE_URL=https://your-video-app.up.railway.app

# Optional explicit URLs for buttons in /start
APP_VIDEO_URL=https://your-video-app.up.railway.app

# URL of the image Mini App shown on /start.
APP2_URL=https://your-image-app.up.railway.app
APP_IMAGE_URL=https://your-image-app.up.railway.app

# URL of the profile Mini App shown on /start.
APP3_URL=https://your-profile-app.up.railway.app
APP_PROFILE_URL=https://your-profile-app.up.railway.app

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set to 'false' to disable SSL for local Postgres
# DATABASE_SSL=false

# Optional
PORT=3000
