# Nano Banana API key from https://nanobananaapi.ai/api-key
NANO_BANANA_API_KEY=your_key_here

# Telegram Bot token — обязателен для оплаты Telegram Stars и webhook (поддерживаются TELEGRAM_BOT_TOKEN, BOT_TOKEN)
TELEGRAM_BOT_TOKEN=your_bot_token_here
# BOT_TOKEN=your_bot_token_here

# Public URL of the app (no trailing slash). Нужен для Stars (createInvoiceLink, setWebhook). On Railway: use the service URL.
BASE_URL=https://your-app.up.railway.app

# Optional
PORT=3000
