# KIE AI API key — https://kie.ai (used for video generation)
KIE_API_KEY=your_kie_api_key_here

# Legacy alias (backward compat — same key works)
# NANO_BANANA_API_KEY=your_key_here

# Telegram Bot token — required for Telegram Stars payments and webhook
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Public URL of the app (Railway URL or ngrok — must be https)
BASE_URL=https://your-app.up.railway.app

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set to 'false' to disable SSL for local Postgres
# DATABASE_SSL=false

# Optional
PORT=3000
